# PocketCodex local configuration.
# Copy this file to remote.env. Never commit the real token.

# Let PocketCodex generate a random token on first start.
# To provide your own, uncomment the next line and use at least 24 random characters.
# REMOTE_CODEX_TOKEN=replace-with-a-secure-random-token

# Optional project roots for new Codex Desktop tasks.
# Configure roots after the first start has generated remote.env.
# Windows separates paths with semicolons; macOS/Linux use colons:
# REMOTE_CODEX_ROOTS=C:\Users\you\Desktop;D:\Projects
# REMOTE_CODEX_ROOTS=/Users/you/Desktop:/Users/you/Projects

# Optional override. Normally PocketCodex discovers the executable bundled
# with the desktop app automatically.
# Windows:
# REMOTE_CODEX_DESKTOP_EXE=C:\Users\you\AppData\Local\OpenAI\Codex\bin\<version>\codex.exe
# macOS:
# REMOTE_CODEX_DESKTOP_EXE=/Applications/ChatGPT.app/Contents/Resources/codex
